# ── Sentiment DB ──────────────────────────────────────────────
SENTIMENT_DB_URL=sqlite:///./sentiment.db

# ── Reddit API (free) ──────────────────────────────────────────
# 1. Go to https://www.reddit.com/prefs/apps
# 2. Click "create another app" → choose "script"
# 3. Fill any name, set redirect URI to http://localhost:8080
# 4. Copy the client_id (under the app name) and client_secret
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USER_AGENT=wc2026-sentiment/1.0

# ── Twitter/X API (optional) ───────────────────────────────────
# 1. Go to https://developer.twitter.com/en/portal/dashboard
# 2. Create a project + app (free tier)
# 3. Copy the Bearer Token from "Keys and Tokens"
# Leave blank to disable Twitter — Reddit still works without it
TWITTER_BEARER_TOKEN=
